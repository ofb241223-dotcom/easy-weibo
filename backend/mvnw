#!/bin/sh

set -eu

BASE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
PROPERTIES_FILE="$WRAPPER_DIR/maven-wrapper.properties"

if [ ! -f "$PROPERTIES_FILE" ]; then
  echo "Missing $PROPERTIES_FILE" >&2
  exit 1
fi

DISTRIBUTION_URL=$(grep '^distributionUrl=' "$PROPERTIES_FILE" | cut -d= -f2-)
if [ -z "$DISTRIBUTION_URL" ]; then
  echo "distributionUrl is not configured in $PROPERTIES_FILE" >&2
  exit 1
fi

ARCHIVE_NAME=$(basename "$DISTRIBUTION_URL")
DISTRIBUTION_NAME=${ARCHIVE_NAME%.tar.gz}
DISTS_DIR="$WRAPPER_DIR/dists"
INSTALL_DIR="$DISTS_DIR/$DISTRIBUTION_NAME"
ARCHIVE_PATH="$DISTS_DIR/$ARCHIVE_NAME"
MVN_BIN="$INSTALL_DIR/bin/mvn"

download_archive() {
  mkdir -p "$DISTS_DIR"

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$DISTRIBUTION_URL" -o "$ARCHIVE_PATH"
    return
  fi

  if command -v wget >/dev/null 2>&1; then
    wget -qO "$ARCHIVE_PATH" "$DISTRIBUTION_URL"
    return
  fi

  echo "Neither curl nor wget is installed, cannot download Maven distribution." >&2
  exit 1
}

install_distribution() {
  TMP_DIR="$DISTS_DIR/.tmp-$DISTRIBUTION_NAME"
  rm -rf "$TMP_DIR" "$INSTALL_DIR"
  mkdir -p "$TMP_DIR"
  tar -xzf "$ARCHIVE_PATH" -C "$TMP_DIR"
  EXTRACTED_DIR=$(find "$TMP_DIR" -mindepth 1 -maxdepth 1 -type d | head -n 1)

  if [ -z "${EXTRACTED_DIR:-}" ]; then
    echo "Failed to extract Maven distribution from $ARCHIVE_PATH" >&2
    exit 1
  fi

  mv "$EXTRACTED_DIR" "$INSTALL_DIR"
  rm -rf "$TMP_DIR"
}

if [ ! -x "$MVN_BIN" ]; then
  [ -f "$ARCHIVE_PATH" ] || download_archive
  install_distribution
fi

exec "$MVN_BIN" "$@"
